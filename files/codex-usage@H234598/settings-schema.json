{
  "layout": {
    "type": "layout",
    "pages": [
      "general-page",
      "format-page",
      "login-page",
      "alerts-page"
    ],
    "general-page": {
      "type": "page",
      "title": "Codex Usage",
      "sections": [
        "command-section",
        "backend-section",
        "refresh-section",
        "display-section"
      ]
    },
    "format-page": {
      "type": "page",
      "title": "Datum & Uhrzeit",
      "sections": [
        "date-style-section",
        "time-style-section"
      ]
    },
    "alerts-page": {
      "type": "page",
      "title": "Warnungen",
      "sections": [
        "alerts-section"
      ]
    },
    "login-page": {
      "type": "page",
      "title": "Reaktivierung",
      "sections": [
        "reactivation-section"
      ]
    },
    "command-section": {
      "type": "section",
      "title": "Datenquelle",
      "keys": [
        "command-path",
        "config-path"
      ]
    },
    "refresh-section": {
      "type": "section",
      "title": "Aktualisierung",
      "keys": [
        "auto-refresh",
        "poll-owner",
        "refresh-interval",
        "refresh-on-open"
      ]
    },
    "backend-section": {
      "type": "section",
      "title": "Abrufwege",
      "keys": [
        "account-backends"
      ]
    },
    "display-section": {
      "type": "section",
      "title": "Panel",
      "keys": [
        "panel-account-mode",
        "panel-percent-source"
      ]
    },
    "date-style-section": {
      "type": "section",
      "title": "Datum pro Account",
      "keys": [
        "account-date-styles"
      ]
    },
    "time-style-section": {
      "type": "section",
      "title": "Uhrzeit pro Account",
      "keys": [
        "account-time-styles"
      ]
    },
    "alerts-section": {
      "type": "section",
      "title": "Benachrichtigungen",
      "keys": [
        "warning-threshold",
        "notify-warnings",
        "notify-errors"
      ]
    },
    "reactivation-section": {
      "type": "section",
      "title": "Abgelaufene Accounts",
      "keys": [
        "show-reactivation-actions",
        "reactivation-browser"
      ]
    }
  },
  "command-path": {
    "type": "entry",
    "description": "Pfad zum codex-usage-Befehl",
    "tooltip": "Ein absoluter Pfad ist am zuverlässigsten. Bei 'codex-usage' wird zusätzlich ~/.local/bin geprüft.",
    "default": "codex-usage"
  },
  "config-path": {
    "type": "entry",
    "description": "Alternative config.toml",
    "tooltip": "Leer lassen, um den Standardpfad der CLI zu verwenden.",
    "default": ""
  },
  "auto-refresh": {
    "type": "switch",
    "description": "Werte automatisch frisch abrufen",
    "default": true
  },
  "poll-owner": {
    "type": "combobox",
    "description": "Regelmäßigen Abruf ausführen durch",
    "options": {
      "Automatisch": "auto",
      "Cinnamon-Applet": "applet",
      "systemd-User-Timer": "systemd"
    },
    "default": "auto"
  },
  "account-backends": {
    "type": "list",
    "description": "Abrufweg pro Account",
    "tooltip": "Doppelklick auf eine Zeile ändert den Abrufweg. Account und Label werden aus der zentralen codex-usage-Konfiguration übernommen.",
    "columns": [
      {
        "id": "account",
        "title": "Account-ID",
        "type": "string"
      },
      {
        "id": "label",
        "title": "Label",
        "type": "string"
      },
      {
        "id": "backend",
        "title": "Abrufweg",
        "type": "integer",
        "options": {
          "Bisheriger Direktabruf": 0,
          "Codex App Server": 1
        }
      }
    ],
    "height": 180,
    "show-buttons": false,
    "default": []
  },
  "account-date-styles": {
    "type": "list",
    "description": "Datumsdarstellung pro Account",
    "columns": [
      {
        "id": "account",
        "title": "Account-ID",
        "type": "string"
      },
      {
        "id": "format",
        "title": "Format",
        "type": "integer",
        "options": {
          "31.12.2026": 0,
          "2026-12-31": 1,
          "31.12.26": 2,
          "31. Dezember 2026": 3
        }
      },
      {
        "id": "font",
        "title": "Schriftart",
        "type": "integer",
        "options": {
          "Theme": 0,
          "Sans": 1,
          "Serif": 2,
          "Monospace": 3
        }
      },
      {
        "id": "size",
        "title": "Größe",
        "tooltip": "0 übernimmt die Schriftgröße des Cinnamon-Themes.",
        "type": "integer",
        "min": 0,
        "max": 48,
        "default": 0
      },
      {
        "id": "bold",
        "title": "Fett",
        "type": "boolean",
        "default": false
      },
      {
        "id": "italic",
        "title": "Kursiv",
        "type": "boolean",
        "default": false
      },
      {
        "id": "background",
        "title": "Hintergrund",
        "type": "integer",
        "options": {
          "Transparent": 0,
          "Dunkel": 1,
          "Hell": 2,
          "Rot": 3,
          "Grün": 4,
          "Blau": 5,
          "Gelb": 6
        }
      }
    ],
    "height": 180,
    "show-buttons": false,
    "default": []
  },
  "account-time-styles": {
    "type": "list",
    "description": "Uhrzeitdarstellung pro Account",
    "columns": [
      {
        "id": "account",
        "title": "Account-ID",
        "type": "string"
      },
      {
        "id": "format",
        "title": "Format",
        "type": "integer",
        "options": {
          "23:59": 0,
          "23:59:59": 1,
          "11:59 PM": 2
        }
      },
      {
        "id": "font",
        "title": "Schriftart",
        "type": "integer",
        "options": {
          "Theme": 0,
          "Sans": 1,
          "Serif": 2,
          "Monospace": 3
        }
      },
      {
        "id": "size",
        "title": "Größe",
        "tooltip": "0 übernimmt die Schriftgröße des Cinnamon-Themes.",
        "type": "integer",
        "min": 0,
        "max": 48,
        "default": 0
      },
      {
        "id": "bold",
        "title": "Fett",
        "type": "boolean",
        "default": false
      },
      {
        "id": "italic",
        "title": "Kursiv",
        "type": "boolean",
        "default": false
      },
      {
        "id": "background",
        "title": "Hintergrund",
        "type": "integer",
        "options": {
          "Transparent": 0,
          "Dunkel": 1,
          "Hell": 2,
          "Rot": 3,
          "Grün": 4,
          "Blau": 5,
          "Gelb": 6
        }
      }
    ],
    "height": 180,
    "show-buttons": false,
    "default": []
  },
  "refresh-interval": {
    "type": "spinbutton",
    "description": "Aktualisierungsintervall in Sekunden",
    "min": 60,
    "max": 3600,
    "step": 60,
    "default": 300
  },
  "refresh-on-open": {
    "type": "switch",
    "description": "Beim Öffnen des Menüs aktualisieren",
    "default": true
  },
  "panel-account-mode": {
    "type": "combobox",
    "description": "Anzahl der Prozentwerte im Panel",
    "tooltip": "Pro Account zeigt einen Wert je Account. Gesamt zeigt den Wert des knappsten Accounts.",
    "options": {
      "Ein Wert pro Account": "per-account",
      "Ein Gesamtwert für alle Accounts": "combined"
    },
    "default": "combined"
  },
  "panel-percent-source": {
    "type": "combobox",
    "description": "Berechnung des angezeigten Prozentwerts",
    "options": {
      "Nur 5-Stunden-Limit": "five-hour",
      "Nur Wochenlimit": "weekly",
      "Mittelwert aus beiden Limits": "average"
    },
    "default": "average"
  },
  "warning-threshold": {
    "type": "spinbutton",
    "description": "Warnschwelle für verbleibende Prozent",
    "min": 0,
    "max": 100,
    "step": 5,
    "default": 20
  },
  "notify-warnings": {
    "type": "switch",
    "description": "Bei Unterschreiten der Warnschwelle benachrichtigen",
    "default": false
  },
  "notify-errors": {
    "type": "switch",
    "description": "Bei Abruf- oder Loginfehlern benachrichtigen",
    "default": false
  },
  "show-reactivation-actions": {
    "type": "switch",
    "description": "Reaktivierungsaktionen bei abgelaufenen Accounts anzeigen",
    "tooltip": "Startet Codex-OAuth in einem eigenen Browserprofil. Cookies des normalen Hauptprofils werden nicht verwendet.",
    "default": true
  },
  "reactivation-browser": {
    "type": "combobox",
    "description": "Isolierter Browser für die Reaktivierung",
    "options": {
      "Automatisch (Vivaldi bevorzugt)": "auto",
      "Vivaldi": "vivaldi",
      "Chromium / Chrome": "chromium",
      "Firefox": "firefox"
    },
    "default": "auto"
  }
}
