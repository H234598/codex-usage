{
  "layout": {
    "type": "layout",
    "pages": [
      "general-page",
      "login-page",
      "alerts-page"
    ],
    "general-page": {
      "type": "page",
      "title": "Codex Usage",
      "sections": [
        "command-section",
        "backend-section",
        "refresh-section",
        "display-section"
      ]
    },
    "alerts-page": {
      "type": "page",
      "title": "Warnungen",
      "sections": [
        "alerts-section"
      ]
    },
    "login-page": {
      "type": "page",
      "title": "Reaktivierung",
      "sections": [
        "reactivation-section"
      ]
    },
    "command-section": {
      "type": "section",
      "title": "Datenquelle",
      "keys": [
        "command-path",
        "config-path"
      ]
    },
    "refresh-section": {
      "type": "section",
      "title": "Aktualisierung",
      "keys": [
        "auto-refresh",
        "poll-owner",
        "refresh-interval",
        "refresh-on-open"
      ]
    },
    "backend-section": {
      "type": "section",
      "title": "Abrufwege",
      "keys": [
        "account-backends"
      ]
    },
    "display-section": {
      "type": "section",
      "title": "Panel",
      "keys": [
        "panel-account-mode",
        "panel-percent-source"
      ]
    },
    "alerts-section": {
      "type": "section",
      "title": "Benachrichtigungen",
      "keys": [
        "warning-threshold",
        "notify-warnings",
        "notify-errors"
      ]
    },
    "reactivation-section": {
      "type": "section",
      "title": "Abgelaufene Accounts",
      "keys": [
        "show-reactivation-actions",
        "reactivation-browser"
      ]
    }
  },
  "command-path": {
    "type": "entry",
    "description": "Pfad zum codex-usage-Befehl",
    "tooltip": "Ein absoluter Pfad ist am zuverlässigsten. Bei 'codex-usage' wird zusätzlich ~/.local/bin geprüft.",
    "default": "codex-usage"
  },
  "config-path": {
    "type": "entry",
    "description": "Alternative config.toml",
    "tooltip": "Leer lassen, um den Standardpfad der CLI zu verwenden.",
    "default": ""
  },
  "auto-refresh": {
    "type": "switch",
    "description": "Werte automatisch frisch abrufen",
    "default": true
  },
  "poll-owner": {
    "type": "combobox",
    "description": "Regelmäßigen Abruf ausführen durch",
    "options": {
      "Automatisch": "auto",
      "Cinnamon-Applet": "applet",
      "systemd-User-Timer": "systemd"
    },
    "default": "auto"
  },
  "account-backends": {
    "type": "list",
    "description": "Abrufweg pro Account",
    "tooltip": "Doppelklick auf eine Zeile ändert den Abrufweg. Account und Label werden aus der zentralen codex-usage-Konfiguration übernommen.",
    "columns": [
      {
        "id": "account",
        "title": "Account-ID",
        "type": "string"
      },
      {
        "id": "label",
        "title": "Label",
        "type": "string"
      },
      {
        "id": "backend",
        "title": "Abrufweg",
        "type": "integer",
        "options": {
          "Bisheriger Direktabruf": 0,
          "Codex App Server": 1
        }
      }
    ],
    "height": 180,
    "show-buttons": false,
    "default": []
  },
  "refresh-interval": {
    "type": "spinbutton",
    "description": "Aktualisierungsintervall in Sekunden",
    "min": 60,
    "max": 3600,
    "step": 60,
    "default": 300
  },
  "refresh-on-open": {
    "type": "switch",
    "description": "Beim Öffnen des Menüs aktualisieren",
    "default": true
  },
  "panel-account-mode": {
    "type": "combobox",
    "description": "Anzahl der Prozentwerte im Panel",
    "tooltip": "Pro Account zeigt einen Wert je Account. Gesamt zeigt den Wert des knappsten Accounts.",
    "options": {
      "Ein Wert pro Account": "per-account",
      "Ein Gesamtwert für alle Accounts": "combined"
    },
    "default": "combined"
  },
  "panel-percent-source": {
    "type": "combobox",
    "description": "Berechnung des angezeigten Prozentwerts",
    "options": {
      "Nur 5-Stunden-Limit": "five-hour",
      "Nur Wochenlimit": "weekly",
      "Mittelwert aus beiden Limits": "average"
    },
    "default": "average"
  },
  "warning-threshold": {
    "type": "spinbutton",
    "description": "Warnschwelle für verbleibende Prozent",
    "min": 0,
    "max": 100,
    "step": 5,
    "default": 20
  },
  "notify-warnings": {
    "type": "switch",
    "description": "Bei Unterschreiten der Warnschwelle benachrichtigen",
    "default": false
  },
  "notify-errors": {
    "type": "switch",
    "description": "Bei Abruf- oder Loginfehlern benachrichtigen",
    "default": false
  },
  "show-reactivation-actions": {
    "type": "switch",
    "description": "Reaktivierungsaktionen bei abgelaufenen Accounts anzeigen",
    "tooltip": "Startet Codex-OAuth in einem eigenen Browserprofil. Cookies des normalen Hauptprofils werden nicht verwendet.",
    "default": true
  },
  "reactivation-browser": {
    "type": "combobox",
    "description": "Isolierter Browser für die Reaktivierung",
    "options": {
      "Automatisch (Vivaldi bevorzugt)": "auto",
      "Vivaldi": "vivaldi",
      "Chromium / Chrome": "chromium",
      "Firefox": "firefox"
    },
    "default": "auto"
  }
}
